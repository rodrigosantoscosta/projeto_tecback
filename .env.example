# =============================================================
# OFICINA - Variáveis de Ambiente
# Copie este arquivo para .env e ajuste os valores
# =============================================================

# -----------------------------------------------------------
# PERFIL ATIVO
# Opções: docker | railway
# - docker  → H2 in-memory (sem banco externo)
# - railway → PostgreSQL no Railway
# -----------------------------------------------------------
SPRING_PROFILES_ACTIVE=docker

# -----------------------------------------------------------
# JWT
# Obrigatório para todos os perfis
# Mínimo 32 caracteres
# -----------------------------------------------------------
JWT_SECRET=troque-por-uma-chave-segura-minimo-32-caracteres
JWT_EXPIRATION_MS=3600000

# -----------------------------------------------------------
# POSTGRESQL (apenas para perfil railway ou docker-postgres)
# Deixe em branco se usar o perfil docker (H2)
# -----------------------------------------------------------
PGHOST=
PGPORT=5432
PGDATABASE=railway
PGUSER=postgres
PGPASSWORD=
