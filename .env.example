# =============================================================
# Copie este arquivo para .env e ajuste os valores
# =============================================================

# -----------------------------------------------------------
# PERFIL ATIVO
# - docker  → H2 in-memory (sem banco externo)
# -----------------------------------------------------------
SPRING_PROFILES_ACTIVE=docker

# -----------------------------------------------------------
# JWT
# Obrigatório para todos os perfis
# Mínimo 32 caracteres
# -----------------------------------------------------------
JWT_SECRET=troque-por-uma-chave-segura-minimo-32-caracteres
JWT_EXPIRATION_MS=3600000